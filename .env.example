# RAGX-Trader — copy to .env for local dev (never commit .env)
# On Railway: set these in the service Variables tab.

# -----------------------------------------------------------------------------
# Server (Railway sets PORT automatically — do not override unless you know why)
# -----------------------------------------------------------------------------
# PORT=8000

# -----------------------------------------------------------------------------
# Binance Spot (Trader tab — required for live charts)
# -----------------------------------------------------------------------------
# com = Binance Global (default)
# us = Binance.US only
# auto = try Global; switch to US if Global returns HTTP 451
RAGX_BINANCE_REGION=auto

# Default chart symbol (Spot pair, uppercase)
# RAGX_SPOT_SYMBOL=BTCUSDT

# -----------------------------------------------------------------------------
# Investor tab — market data (set at least one key for live equities/crypto quotes)
# -----------------------------------------------------------------------------
# FINNHUB_API_KEY=
# TWELVE_DATA_API_KEY=

# auto | finnhub | twelve_data
# RAGX_INVESTOR_MARKET_PROVIDER=auto

# 1 = synthetic demo candles only (not for public production)
# RAGX_INVESTOR_MARKET_DEMO=0

# finnhub | alpha_vantage | twelve_data | mock
# RAGX_INVESTOR_PROVIDER=mock

# -----------------------------------------------------------------------------
# Investor tab — news
# -----------------------------------------------------------------------------
# ALPHA_VANTAGE_API_KEY=
# NEWSAPI_API_KEY=
# NEWS_API_KEY=

# auto | finnhub | alpha_vantage | newsapi | mock
# RAGX_NEWS_PROVIDER=auto

# -----------------------------------------------------------------------------
# Debug (leave unset in production)
# -----------------------------------------------------------------------------
# RAGX_CANDLE_DEBUG=0
# RAGX_DEBUG=0
# RAGX_CANDLE_PROCESSOR_DEBUG=0
# RAGX_CANDLE_PIPELINE=0
# RAGX_CANDLE_ALIGN_DEBUG=0

# -----------------------------------------------------------------------------
# Access gate (Phase 2 — not implemented yet)
# -----------------------------------------------------------------------------
# RAGX_GATE_ENABLED=0
# RAGX_ACCESS_CODE=
